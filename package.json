{
  "name": "marketplace-engine",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @marketplace-engine/dashboard",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "db:seed": "tsx packages/database/src/seed.ts",
    "queue:cleanup": "tsx scripts/cleanup-outreach-queue.ts",
    "messages:refresh": "tsx scripts/refresh-ready-messages.ts",
    "sellers:backfill": "node --env-file=.env --import tsx scripts/backfill-seller-profiles.ts",
    "competitors:reclassify": "tsx scripts/reclassify-competitors.ts",
    "opportunities:remove-car-sized": "tsx scripts/remove-car-sized-opportunities.ts",
    "email:send-now": "tsx scripts/send-opportunity-alerts.ts",
    "setup:facebook": "./scripts/setup-facebook-mcp.sh",
    "worker": "tsx apps/worker/src/index.ts",
    "worker:status": "./scripts/worker-service-status.sh",
    "worker:restart": "./scripts/restart-worker-service.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.12.0",
    "pg": "^8.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@opennextjs/cloudflare": "^1.20.2",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.20.0",
    "eslint": "^9.31.0",
    "prisma": "^6.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.113.0"
  }
}
